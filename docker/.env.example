# ============================================
# Docker Compose Environment Variables
# ============================================
# Bu dosyayı docker/.env olarak kopyalayın:
#   cp docker/.env.example docker/.env

# --- App ---
APP_NAME=education-demo
# APP_NAME=web

# --- Database ---
DB_USER=postgres
DB_PASSWORD=super-secret-db-password
DB_NAME=education_demo
DB_PORT=5432

# --- Payload CMS ---
PAYLOAD_SECRET=your-very-long-random-secret-min-32-chars

# --- Site ---
SITE_URL=https://yourdomain.com

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=info@yourdomain.com
RESEND_FROM_NAME=Almanya Eğitim Danışmanlığı
EMAIL_TO=admin@yourdomain.com

# --- Analytics (opsiyonel) ---
GA_ID=
# GTM_ID=

# --- Bot Koruması (opsiyonel) ---
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- GraphQL ---
DISABLE_GRAPHQL=true
